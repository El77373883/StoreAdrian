<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    
    <!-- SEO PROFESIONAL -->
    <title>ADRIANHATS | Tienda Oficial - Gorras Premium & Fragancias</title>
    <meta name="description" content="Descubre nuestra colección completa de gorras premium con detalles en strass y fragancias beast mode. Envíos a todo México.">
    <meta name="keywords" content="gorras premium, fragancias beast mode, adrianhats, tienda online, strass">
    <meta property="og:title" content="ADRIANHATS | Tienda Oficial">
    <meta property="og:type" content="website">
    <meta property="og:description" content="Gorras de diseñador y fragancias de inspiración. Beast mode.">
    <meta name="twitter:card" content="summary_large_image">
    
    <style>
        /* ========== VARIABLES ========== */
        :root {
            --bg-color: #fbfbfd;
            --text-main: #1d1d1f;
            --text-secondary: #86868b;
            --card-bg: #ffffff;
            --accent: #000000;
            --border-color: #d2d2d7;
            --nav-bg: rgba(251, 251, 253, 0.85);
            --success: #28cd41;
            --warning: #ff9500;
            --gradient-start: #667eea;
            --gradient-end: #764ba2;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg-color: #000000;
                --text-main: #f5f5f7;
                --text-secondary: #a1a1a6;
                --card-bg: #1c1c1e;
                --accent: #ffffff;
                --border-color: #424245;
                --nav-bg: rgba(0, 0, 0, 0.85);
            }
        }

        /* ========== RESET ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        html {
            scroll-behavior: smooth;
            background-color: var(--bg-color);
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ========== OVERLAY PARA MENÚ ========== */
        .menu-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 9997;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }

        .menu-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* ========== ANUNCIO SUPERIOR ========== */
        .announcement-bar {
            background: var(--accent);
            color: var(--bg-color);
            text-align: center;
            padding: 8px;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.3px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 10000;
        }

        /* ========== NAVEGACIÓN GLASS ========== */
        nav {
            position: fixed;
            top: 37px;
            width: 100%;
            height: 60px;
            background: var(--nav-bg);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 5%;
            z-index: 9999;
        }

        .brand-logo {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--text-main);
            text-decoration: none;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 32px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 14px;
            font-weight: 500;
            opacity: 0.8;
            transition: opacity 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .nav-links a:hover {
            opacity: 1;
        }

        .nav-links a.active {
            opacity: 1;
            font-weight: 600;
        }

        /* Botón Hamburguesa */
        .hamburger {
            display: none;
            flex-direction: column;
            justify-content: space-around;
            width: 24px;
            height: 24px;
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 0;
            z-index: 10000;
        }

        .hamburger span {
            width: 24px;
            height: 2px;
            background: var(--text-main);
            border-radius: 10px;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        /* Menú Móvil */
        .mobile-menu {
            position: fixed;
            top: 97px;
            left: 0;
            width: 100%;
            background: var(--nav-bg);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            padding: 20px 5%;
            display: flex;
            flex-direction: column;
            gap: 5px;
            z-index: 9998;
            transform: translateX(-100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .mobile-menu.active {
            transform: translateX(0);
        }

        .mobile-menu a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 20px;
            font-weight: 500;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border-color);
            opacity: 0;
            transform: translateX(-20px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            border-radius: 12px;
        }

        .mobile-menu.active a {
            opacity: 1;
            transform: translateX(0);
        }

        .mobile-menu a:nth-child(1) { transition-delay: 0.05s; }
        .mobile-menu a:nth-child(2) { transition-delay: 0.1s; }
        .mobile-menu a:nth-child(3) { transition-delay: 0.15s; }
        .mobile-menu a:nth-child(4) { transition-delay: 0.2s; }

        /* ========== HERO STORE ========== */
        .store-hero {
            height: 50vh;
            min-height: 400px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            background: linear-gradient(135deg, var(--card-bg) 0%, var(--bg-color) 100%);
            margin-top: 97px;
            position: relative;
            overflow: hidden;
        }

        .store-hero::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, var(--border-color) 0%, transparent 70%);
            opacity: 0.1;
            animation: rotate 30s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .store-hero h1 {
            font-size: clamp(36px, 7vw, 70px);
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }

        .store-hero p {
            font-size: clamp(16px, 2.5vw, 20px);
            color: var(--text-secondary);
            font-weight: 400;
            max-width: 600px;
            position: relative;
            z-index: 1;
        }

        /* ========== FILTROS Y CATEGORÍAS ========== */
        .category-tabs {
            display: flex;
            justify-content: center;
            gap: 15px;
            padding: 30px 5% 0;
            max-width: 1400px;
            margin: 0 auto;
            flex-wrap: wrap;
        }

        .category-tab {
            padding: 10px 24px;
            border-radius: 980px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .category-tab:hover {
            border-color: var(--text-main);
        }

        .category-tab.active {
            background: var(--accent);
            color: var(--bg-color);
            border-color: var(--accent);
        }

        /* ========== TIENDA ========== */
        .store-section {
            padding: 40px 5% 100px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        .section-header {
            font-size: clamp(28px, 5vw, 42px);
            font-weight: 700;
            margin-bottom: 30px;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .section-header span {
            color: var(--text-secondary);
            font-size: 16px;
            font-weight: 400;
            margin-left: auto;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        /* Product Card */
        .product-card {
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            border: 1px solid var(--border-color);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        .product-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: var(--accent);
            color: var(--bg-color);
            padding: 4px 10px;
            border-radius: 980px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            z-index: 10;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .product-badge.bestseller {
            background: #ff9500;
            color: white;
        }

        .product-badge.new {
            background: #007aff;
            color: white;
        }

        .product-badge.limited {
            background: #ff3b30;
            color: white;
        }

        .product-image {
            width: 100%;
            aspect-ratio: 1 / 1;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, var(--border-color) 0%, var(--card-bg) 100%);
        }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .product-card:hover .product-image img {
            transform: scale(1.08);
        }

        .product-info {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-category {
            font-size: 11px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .product-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: -0.3px;
        }

        .product-rating {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 10px;
        }

        .stars {
            color: #ff9500;
            font-size: 12px;
        }

        .rating-count {
            color: var(--text-secondary);
            font-size: 12px;
        }

        .product-desc {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 16px;
            flex-grow: 1;
            line-height: 1.5;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }

        .price {
            font-size: 20px;
            font-weight: 700;
        }

        .price-small {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .btn-buy {
            background: var(--text-main);
            color: var(--bg-color);
            border: none;
            padding: 10px 18px;
            border-radius: 980px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.2s ease;
            letter-spacing: 0.5px;
        }

        .btn-buy:hover {
            opacity: 0.9;
            transform: scale(1.02);
        }

        .btn-buy:active {
            transform: scale(0.95);
        }

        /* ========== CARRITO FLOTANTE ========== */
        .cart-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 65px;
            height: 65px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            cursor: pointer;
            z-index: 9997;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            border: 3px solid var(--bg-color);
        }

        .cart-float:hover {
            transform: scale(1.08);
            box-shadow: 0 15px 50px rgba(0,0,0,0.4);
        }

        .cart-float svg {
            width: 30px;
            height: 30px;
            fill: var(--bg-color);
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--success);
            color: white;
            font-size: 13px;
            font-weight: 700;
            min-width: 26px;
            height: 26px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid var(--bg-color);
            padding: 0 6px;
        }

        /* ========== FOOTER ========== */
        footer {
            background: var(--card-bg);
            border-top: 1px solid var(--border-color);
            padding: 50px 5% 25px;
            margin-top: auto;
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 40px;
        }

        .footer-col h4 {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li {
            margin-bottom: 10px;
        }

        .footer-col ul li a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 13px;
            transition: color 0.2s ease;
        }

        .footer-col ul li a:hover {
            color: var(--text-main);
        }

        .social-links {
            display: flex;
            gap: 15px;
            margin-top: 10px;
        }

        .social-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 24px;
            transition: all 0.2s ease;
        }

        .social-links a:hover {
            color: var(--text-main);
            transform: translateY(-3px);
        }

        .newsletter {
            margin-top: 15px;
        }

        .newsletter-input {
            display: flex;
            gap: 8px;
        }

        .newsletter-input input {
            flex: 1;
            padding: 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 980px;
            background: var(--bg-color);
            color: var(--text-main);
            font-size: 13px;
            outline: none;
        }

        .newsletter-input button {
            background: var(--accent);
            color: var(--bg-color);
            border: none;
            padding: 10px 16px;
            border-radius: 980px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
        }

        .copyright {
            text-align: center;
            margin-top: 50px;
            padding-top: 25px;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 13px;
        }

        /* ========== TOAST ========== */
        .toast {
            position: fixed;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--success);
            color: white;
            padding: 12px 24px;
            border-radius: 980px;
            font-size: 14px;
            font-weight: 600;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            z-index: 10001;
            opacity: 0;
            transition: opacity 0.3s ease, transform 0.3s ease;
            white-space: nowrap;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(-10px);
        }

        /* ========== MOBILE ========== */
        @media (max-width: 768px) {
            .announcement-bar {
                font-size: 11px;
                padding: 6px;
            }
            
            nav {
                top: 29px;
            }
            
            .nav-links {
                display: none;
            }
            
            .hamburger {
                display: flex;
            }
            
            .hamburger.active span:nth-child(1) {
                transform: rotate(45deg) translate(6px, 6px);
            }
            
            .hamburger.active span:nth-child(2) {
                opacity: 0;
                transform: translateX(-10px);
            }
            
            .hamburger.active span:nth-child(3) {
                transform: rotate(-45deg) translate(6px, -6px);
            }
            
            .store-hero {
                margin-top: 89px;
                min-height: 300px;
            }
            
            .mobile-menu {
                top: 89px;
            }
            
            .category-tabs {
                padding: 20px 5% 0;
                gap: 8px;
            }
            
            .category-tab {
                padding: 8px 16px;
                font-size: 12px;
            }
            
            .store-section {
                padding: 30px 20px 80px;
            }
            
            .product-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
            
            .product-info {
                padding: 15px;
            }
            
            .product-title {
                font-size: 16px;
            }
            
            .price {
                font-size: 18px;
            }
            
            .btn-buy {
                padding: 8px 12px;
                font-size: 11px;
            }
            
            .cart-float {
                bottom: 20px;
                right: 20px;
                width: 55px;
                height: 55px;
            }
            
            .footer-content {
                grid-template-columns: 1fr;
                text-align: center;
            }
            
            .social-links {
                justify-content: center;
            }
            
            .newsletter-input {
                max-width: 300px;
                margin: 0 auto;
            }
            
            .toast {
                bottom: 90px;
                white-space: normal;
                width: 90%;
                text-align: center;
            }
        }
    </style>
</head>
<body>

    <!-- ========== ANUNCIO SUPERIOR ========== -->
    <div class="announcement-bar">
        🚚 ENVÍO GRATIS en pedidos +$1,500 MXN | ⚡ Beast Mode Garantizado
    </div>

    <!-- Overlay para menú móvil -->
    <div class="menu-overlay" id="menuOverlay"></div>

    <!-- ========== NAVEGACIÓN ========== -->
    <nav>
        <a href="#" class="brand-logo">Adrianhats</a>
        <div class="nav-links">
            <a href="#" class="active">Tienda</a>
            <a href="#gorras">Gorras</a>
            <a href="#fragancias">Fragancias</a>
            <a href="#contacto">Contacto</a>
        </div>
        <button class="hamburger" id="hamburgerBtn" aria-label="Menú">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </nav>

    <!-- Menú Móvil -->
    <div class="mobile-menu" id="mobileMenu">
        <a href="#">🏠 Tienda</a>
        <a href="#gorras">🧢 Gorras</a>
        <a href="#fragancias">🌊 Fragancias</a>
        <a href="#contacto">📞 Contacto</a>
    </div>

    <!-- ========== HERO STORE ========== -->
    <section class="store-hero">
        <h1>Catálogo Completo</h1>
        <p>Gorras premium • Fragancias beast mode • Calidad garantizada</p>
    </section>

    <!-- ========== CATEGORY TABS ========== -->
    <div class="category-tabs">
        <button class="category-tab active" onclick="filterProducts('all')">Todos</button>
        <button class="category-tab" onclick="filterProducts('gorras')">🧢 Gorras</button>
        <button class="category-tab" onclick="filterProducts('fragancias')">🌊 Fragancias</button>
        <button class="category-tab" onclick="filterProducts('bestseller')">🔥 Best Sellers</button>
    </div>

    <!-- ========== GORRAS ========== -->
    <section class="store-section" id="gorras">
        <h2 class="section-header">
            🧢 Headwear Collection
            <span>4 productos</span>
        </h2>
        <div class="product-grid">
            <!-- Gorra 1 -->
            <div class="product-card" data-category="gorras bestseller">
                <span class="product-badge bestseller">🔥 Best Seller</span>
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1588850561407-ed78c282e89b?w=600&auto=format&fit=crop" alt="Classic Heavy Cotton" loading="lazy">
                </div>
                <div class="product-info">
                    <div class="product-category">Gorras</div>
                    <h3 class="product-title">Classic Heavy Cotton</h3>
                    <div class="product-rating">
                        <span class="stars">★★★★★</span>
                        <span class="rating-count">(128)</span>
                    </div>
                    <p class="product-desc">Algodón 400gsm. Bordado 3D frontal. Strass premium.</p>
                    <div class="product-footer">
                        <div>
                            <span class="price">$850</span>
                            <span class="price-small"> MXN</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart('Classic Heavy Cotton', 850)">Comprar</button>
                    </div>
                </div>
            </div>

            <!-- Gorra 2 -->
            <div class="product-card" data-category="gorras">
                <span class="product-badge new">✨ Nuevo</span>
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1622444574228-1e22d2868936?w=600&auto=format&fit=crop" alt="Paisley Edition" loading="lazy">
                </div>
                <div class="product-info">
                    <div class="product-category">Gorras</div>
                    <h3 class="product-title">Paisley Edition</h3>
                    <div class="product-rating">
                        <span class="stars">★★★★½</span>
                        <span class="rating-count">(67)</span>
                    </div>
                    <p class="product-desc">Diseño exclusivo bajo visera. Estructura firme premium.</p>
                    <div class="product-footer">
                        <div>
                            <span class="price">$790</span>
                            <span class="price-small"> MXN</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart('Paisley Edition', 790)">Comprar</button>
                    </div>
                </div>
            </div>

            <!-- Gorra 3 -->
            <div class="product-card" data-category="gorras bestseller">
                <span class="product-badge bestseller">🔥 Best Seller</span>
                <div class="product-image">
