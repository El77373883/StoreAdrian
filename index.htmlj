<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ADRIANHATS | Official Store</title>
    <style>
        :root {
            --bg-color: #fbfbfd;
            --text-main: #1d1d1f;
            --text-secondary: #86868b;
            --card-bg: #ffffff;
            --accent: #000000;
            --border-color: #d2d2d7;
            --nav-bg: rgba(251, 251, 253, 0.8);
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg-color: #000000;
                --text-main: #f5f5f7;
                --text-secondary: #a1a1a6;
                --card-bg: #1c1c1e;
                --accent: #ffffff;
                --border-color: #424245;
                --nav-bg: rgba(0, 0, 0, 0.8);
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.5;
        }

        /* Glassmorphism Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 60px;
            background: var(--nav-bg);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 5%;
            z-index: 9999;
        }

        .brand-logo {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: var(--text-main);
            text-decoration: none;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 24px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 14px;
            font-weight: 500;
            opacity: 0.8;
            transition: opacity 0.2s ease;
        }

        .nav-links a:hover {
            opacity: 1;
        }

        /* Hero Section (Cinematic) */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            background: var(--bg-color);
            margin-top: 30px;
        }

        .hero h1 {
            font-size: clamp(40px, 8vw, 80px);
            font-weight: 700;
            letter-spacing: -1.5px;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: clamp(18px, 3vw, 24px);
            color: var(--text-secondary);
            font-weight: 400;
            max-width: 600px;
            margin-bottom: 30px;
        }

        .btn-primary {
            background-color: var(--accent);
            color: var(--bg-color);
            padding: 12px 24px;
            border-radius: 980px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

        .btn-primary:active {
            transform: scale(0.95);
        }

        /* Store Section */
        .store-section {
            padding: 100px 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header {
            font-size: clamp(28px, 5vw, 48px);
            font-weight: 700;
            margin-bottom: 50px;
            text-align: center;
            letter-spacing: -0.5px;
        }

        /* Grid System for iPhone & PC */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        /* Clean Product Cards */
        .product-card {
            background: var(--card-bg);
            border-radius: 18px;
            overflow: hidden;
            transition: box-shadow 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .product-card:hover {
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        }

        .product-image {
            width: 100%;
            aspect-ratio: 1 / 1;
            background-color: var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            font-size: 14px;
        }

        .product-info {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .product-desc {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }

        .price {
            font-size: 18px;
            font-weight: 600;
        }

        .btn-buy {
            background: var(--text-main);
            color: var(--bg-color);
            border: none;
            padding: 8px 16px;
            border-radius: 980px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
        }

        /* Mobile adjustments */
        @media (max-width: 768px) {
            .nav-links {
                display: none; /* In a real app, this would be a hamburger menu */
            }
            .store-section {
                padding: 60px 20px;
            }
            .product-grid {
                gap: 20px;
            }
        }
    </style>
</head>
<body>

    <nav>
        <a href="#" class="brand-logo">Adrianhats</a>
        <div class="nav-links">
            <a href="#gorras">Headwear</a>
            <a href="#fragancias">Fragrances</a>
        </div>
    </nav>

    <section class="hero">
        <h1>Diseño y Estela.</h1>
        <p>Materiales premium. Proyección beast mode. Creado para destacar.</p>
        <a href="#gorras" class="btn-primary">Explorar Colección</a>
    </section>

    <section class="store-section" id="gorras">
        <h2 class="section-header">Headwear</h2>
        <div class="product-grid">
            <div class="product-card">
                <div class="product-image">Foto de gorra Heavy Cotton</div>
                <div class="product-info">
                    <h3 class="product-title">Classic Heavy Cotton</h3>
                    <p class="product-desc">Algodón de alto gramaje con bordado 3D frontal. Detalles en strass meticulosamente colocados a mano.</p>
                    <div class="product-footer">
                        <span class="price">$850</span>
                        <button class="btn-buy">Comprar</button>
                    </div>
                </div>
            </div>
            <div class="product-card">
                <div class="product-image">Foto de gorra Paisley</div>
                <div class="product-info">
                    <h3 class="product-title">Paisley Edition</h3>
                    <p class="product-desc">Estructura firme con diseño exclusivo bajo la visera. El ajuste perfecto que estabas buscando.</p>
                    <div class="product-footer">
                        <span class="price">$790</span>
                        <button class="btn-buy">Comprar</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="store-section" id="fragancias">
        <h2 class="section-header">Fragrances</h2>
        <div class="product-grid">
            <div class="product-card">
                <div class="product-image">Foto de inspiración L'Immensité</div>
                <div class="product-info">
                    <h3 class="product-title">Aura Infinita</h3>
                    <p class="product-desc">Inspiración L'Immensité. Cítricos vibrantes, jengibre y una estela elegante que proyecta por horas.</p>
                    <div class="product-footer">
                        <span class="price">$1,200</span>
                        <button class="btn-buy">Comprar</button>
                    </div>
                </div>
            </div>
            <div class="product-card">
                <div class="product-image">Foto de inspiración Elixir/Erba Pura</div>
                <div class="product-info">
                    <h3 class="product-title">Elixir Beast Mode</h3>
                    <p class="product-desc">Potencia absoluta. Una mezcla densa y magnética con duración nuclear en piel y ropa.</p>
                    <div class="product-footer">
                        <span class="price">$1,450</span>
                        <button class="btn-buy">Comprar</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

</body>
</html>
